# ============================================
# 🚀 T3CK Core Environment Configuration
# ============================================
# Copy this file to .env and fill with your values
# For development: use localhost
# For staging: use your staging environment
# For production: use secure, encrypted values in secrets manager

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
LOG_LEVEL=info
ENVIRONMENT=development

# ============================================
# SERVICE PORTS
# ============================================
AUTH_SERVICE_PORT=3001
WEBHOOK_SERVICE_PORT=3002
TENANT_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3010
PRODUCT_SERVICE_PORT=3004
ORDER_SERVICE_PORT=3011
USER_DASHBOARD_SERVICE_PORT=3015
API_GATEWAY_PORT=3000

# ============================================
# AWS CONFIGURATION
# ============================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=AKIA_PLACEHOLDER
AWS_SECRET_ACCESS_KEY=PLACEHOLDER

# ============================================
# FIREBASE AUTHENTICATION & DATABASE
# ============================================
FIREBASE_PROJECT_ID=t3ck-core-dev
FIREBASE_API_KEY=AIza_PLACEHOLDER
FIREBASE_AUTH_DOMAIN=t3ck-core-dev.firebaseapp.com
FIREBASE_DATABASE_URL=https://t3ck-core-dev.firebaseio.com
FIREBASE_STORAGE_BUCKET=t3ck-core-dev.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:abc123def456
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# ============================================
# JWT & AUTHENTICATION (CRITICAL)
# ============================================
# Generate with: openssl genrsa -out private.key 2048
# Then: openssl rsa -in private.key -pubout -out public.key
# On Windows PowerShell, convert to single-line escaped format:
# $pk=(Get-Content private.key -Raw).Replace("`r`n","`n").Replace("`n","\\n")
# $pub=(Get-Content public.key -Raw).Replace("`r`n","`n").Replace("`n","\\n")
# Set JWT_PRIVATE_KEY=$pk and JWT_PUBLIC_KEY=$pub
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA0Z8...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0B...\n-----END PUBLIC KEY-----
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# ============================================
# AWS COGNITO (OPTIONAL)
# ============================================
COGNITO_CLIENT_ID=PLACEHOLDER
COGNITO_USER_POOL_ID=us-east-1_PLACEHOLDER
COGNITO_REGION=us-east-1

# ============================================
# DATABASE (MySQL via RDS)
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=t3ck_admin
DATABASE_PASSWORD=SECURE_PASSWORD_HERE
DATABASE_NAME=t3ck_tenants
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=2
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000

# ============================================
# REDIS (Cache & Queue)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# ============================================
# ENCRYPTION & KEY MANAGEMENT (AWS KMS)
# ============================================
# KMS Key ID for encryption operations
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012

# Secret encryption key (generate with: openssl rand -base64 32)
SECRET_ENCRYPTION_KEY=PLACEHOLDER_BASE64_ENCODED_32_BYTES

# ============================================
# PAYMENT INTEGRATION (AbacatePay)
# ============================================
PAYMENT_PROVIDER=abacatepay
PAYMENT_MOCK_MODE=true
ABACATEPAY_BASE_URL=https://api.abacatepay.com/v2
ABACATEPAY_API_KEY=abc_live_or_dev_PLACEHOLDER
ABACATEPAY_WEBHOOK_URL_SECRET=generate-a-random-url-secret
ABACATEPAY_WEBHOOK_PUBLIC_KEY=official-or-dashboard-hmac-public-key
CHECKOUT_MERCHANT_NAME=T3CK Store
CHECKOUT_LOGO_URL=https://example.com/logo.png
CHECKOUT_PRIMARY_COLOR=#111827
AUTH_SERVICE_URL=http://localhost:3001
ADMIN_SERVICE_URL=http://localhost:3006
PAYMENT_SERVICE_URL=http://localhost:3010
ORDER_SERVICE_URL=http://localhost:3011
PRODUCT_SERVICE_URL=http://localhost:3004
SHIPPING_SERVICE_URL=http://localhost:3012
USER_DASHBOARD_SERVICE_URL=http://localhost:3015
INTERNAL_SERVICE_TOKEN=generate-a-long-random-internal-token
USER_DASHBOARD_ALLOWED_ROLES=admin,user,usuario,customer
USER_DASHBOARD_INTEGRATION_READ_ROLES=owner,admin,manager,integration_manager,user,usuario,customer
USER_DASHBOARD_INTEGRATION_WRITE_ROLES=owner,admin,manager,integration_manager,user,usuario,customer
USER_DASHBOARD_PAGESPEED_RUN_ROLES=owner,admin,manager,integration_manager,user,usuario,customer
INTEGRATION_STATE_BACKEND=firestore
INTEGRATION_STATE_FILE=./data/user-dashboard-integrations-state.json
INTEGRATION_FIRESTORE_COLLECTION_PREFIX=
INTEGRATION_TOKEN_ENCRYPTION_KEY=generate-a-32-byte-random-secret
OAUTH_STATE_SECRET=generate-a-random-oauth-state-secret
MARKETPLACE_MOCK_MODE=true
MERCADO_LIVRE_CLIENT_ID=placeholder
MERCADO_LIVRE_CLIENT_SECRET=placeholder
MERCADO_LIVRE_TOKEN_URL=https://api.mercadolibre.com/oauth/token
MERCADO_LIVRE_WEBHOOK_SECRET=placeholder
TIKTOK_SHOP_CLIENT_ID=placeholder
TIKTOK_SHOP_CLIENT_SECRET=placeholder
TIKTOK_SHOP_TOKEN_URL=https://auth.tiktok-shops.com/api/v2/token/get
TIKTOK_SHOP_WEBHOOK_SECRET=placeholder
SHOPEE_CLIENT_ID=placeholder
SHOPEE_CLIENT_SECRET=placeholder
SHOPEE_TOKEN_URL=https://partner.shopeemobile.com/api/v2/auth/token/get
SHOPEE_WEBHOOK_SECRET=placeholder
GOOGLE_PAGESPEED_API_KEY=placeholder
PAGESPEED_MOCK_MODE=true
PAGESPEED_TESTS_PER_HOUR=10
PAYMENT_ALLOWED_RETURN_ORIGINS=https://loja.exemplo
PAYMENT_STATE_FILE=./data/payment-service-state.json
ORDER_STATE_FILE=./data/order-service-state.json
# Development compatibility only. Keep false/unset in production.
ORDER_ALLOW_CLIENT_SHIPPING_COST=false

# ============================================
# FRONTEND APPLICATIONS
# ============================================
VITE_GATEWAY_BASE_URL=http://localhost:3000

# ============================================
# EMAIL SERVICE
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@t3ck.com
SMTP_PASSWORD=PLACEHOLDER
SMTP_FROM_NAME=T3CK Core
SMTP_FROM_EMAIL=noreply@t3ck.com

# Alert emails
ALERT_EMAIL=ops@t3ck.com
SUPPORT_EMAIL=support@t3ck.com

# ============================================
# OBSERVABILITY & MONITORING
# ============================================
# Sentry (Error Tracking)
SENTRY_DSN=https://PLACEHOLDER@sentry.io/PLACEHOLDER

# Jaeger (Distributed Tracing)
JAEGER_HOST=localhost
JAEGER_PORT=6831
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Prometheus Metrics
PROMETHEUS_PORT=9090

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=1000
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_SIGNATURE_ALGORITHM=HMAC-SHA256

# ============================================
# API CONFIGURATION
# ============================================
API_BASE_URL=http://localhost:3000
API_TIMEOUT_MS=30000
API_MAX_REQUEST_SIZE=10mb
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BY_TENANT=true
RATE_LIMIT_BY_IP=true

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_PAYMENT_ENABLED=true
FEATURE_SHIPPING_ENABLED=true
FEATURE_ANALYTICS_ENABLED=false
FEATURE_INVENTORY_TRACKING=true
FEATURE_SUBSCRIPTION=false

# ============================================
# ENVIRONMENT-SPECIFIC
# ============================================

# Development only
DEBUG=false
MOCK_PAYMENT_GATEWAY=false
ALLOW_INSECURE_HTTP=false

# Staging
# STAGING_WEBHOOK_URL=https://staging.t3ck.com/webhooks
# STAGING_ADMIN_EMAIL=admin@staging.t3ck.com

# Production
# PROD_WEBHOOK_URL=https://api.t3ck.com/webhooks
# PROD_ADMIN_EMAIL=admin@t3ck.com
# PROD_BACKUP_BUCKET=s3://t3ck-backups-prod

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# Slack Integration
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SLACK_ALERT_CHANNEL=#alerts
# SLACK_LOG_CHANNEL=#logs

# GitHub
# GITHUB_TOKEN=ghp_PLACEHOLDER
# GITHUB_WEBHOOK_SECRET=PLACEHOLDER

# Analytics
# SEGMENT_WRITE_KEY=PLACEHOLDER
# AMPLITUDE_API_KEY=PLACEHOLDER

# ============================================
# INTERNAL USE ONLY
# ============================================
# Do NOT commit these to repository

# Tenant provisioning
TF_VARS_FILE=terraform.staging.tfvars

# Database migration
DB_MIGRATION_BATCH_SIZE=100

# Cache configuration
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=10000
