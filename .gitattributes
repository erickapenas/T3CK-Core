# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf

# PowerShell scripts
*.ps1 text eol=crlf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Terraform files
*.tf text eol=lf
*.tfvars text eol=lf

# JSON files
*.json text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf
