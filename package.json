{
  "name": "motor-t3ck",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma T3CK Core - Multi-tenant SaaS Platform",
  "workspaces": [
    "packages/*",
    "services/*",
    "e2e"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "pnpm --filter @t3ck/e2e-tests test",
    "test:e2e:staging": "pnpm --filter @t3ck/e2e-tests test:staging",
    "test:e2e:production": "pnpm --filter @t3ck/e2e-tests test:production",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean",
    "dev": "concurrently \"pnpm --filter @t3ck/auth-service dev\" \"pnpm --filter @t3ck/webhook-service dev\" \"pnpm --filter @t3ck/tenant-service dev\"",
    "setup": "bash scripts/setup.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
