{
  "name": "motor-t3ck",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma T3CK Core - Multi-tenant SaaS Platform",
  "workspaces": [
    "packages/*",
    "services/*",
    "e2e"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter @t3ck/shared test && pnpm --filter @t3ck/sdk test",
    "test:watch": "pnpm -r test --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "pnpm --filter @t3ck/payment-service test && pnpm --filter @t3ck/order-service test && pnpm --filter @t3ck/shipping-service test",
    "test:e2e": "pnpm --filter @t3ck/e2e-tests test",
    "test:e2e:flows": "pnpm --filter @t3ck/e2e-tests test -- flows.e2e.test.ts",
    "test:e2e:staging": "pnpm --filter @t3ck/e2e-tests test:staging",
    "test:e2e:production": "pnpm --filter @t3ck/e2e-tests test:production",
    "test:performance:load": "node scripts/run-k6.js tests/performance/k6-load.js",
    "test:performance:stress": "node scripts/run-k6.js tests/performance/k6-stress.js",
    "test:performance:spike": "node scripts/run-k6.js tests/performance/k6-spike.js",
    "test:performance:db": "node scripts/db-query-optimization-check.js",
    "test:performance:cache": "node scripts/cache-hit-rate-analysis.js",
    "test:security:owasp": "pnpm --filter @t3ck/api-gateway test -- owasp-top10.test.ts",
    "test:security:rate-limit": "pnpm --filter @t3ck/api-gateway test -- security-regression.test.ts",
    "test:security:token-exp": "pnpm --filter @t3ck/api-gateway test -- security-regression.test.ts",
    "test:security:deps": "pnpm audit --audit-level=high",
    "test:security:pentest": "node scripts/run-security-pentest.js",
    "test:security": "pnpm test:security:owasp && pnpm test:security:rate-limit && pnpm test:security:deps",
    "coverage:targets": "node scripts/check-coverage-targets.js",
    "coverage:regression": "node scripts/check-coverage-regression.js",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean",
    "dev": "concurrently \"pnpm --filter @t3ck/api-gateway dev\" \"pnpm --filter @t3ck/auth-service dev\" \"pnpm --filter @t3ck/webhook-service dev\" \"pnpm --filter @t3ck/tenant-service dev\" \"pnpm --filter @t3ck/payment-service dev\" \"pnpm --filter @t3ck/product-service dev\" \"pnpm --filter @t3ck/order-service dev\" \"pnpm --filter @t3ck/shipping-service dev\" \"pnpm --filter @t3ck/admin-service dev\" \"pnpm --filter @t3ck/admin-dashboard dev\" \"pnpm --filter @t3ck/admin-unified-dashboard dev\" \"pnpm --filter @t3ck/media-service dev\" \"pnpm --filter @t3ck/edge-service dev\"",
    "dev:gateway": "pnpm --filter @t3ck/api-gateway dev",
    "dev:core": "concurrently \"pnpm --filter @t3ck/auth-service dev\" \"pnpm --filter @t3ck/webhook-service dev\" \"pnpm --filter @t3ck/tenant-service dev\" \"pnpm --filter @t3ck/payment-service dev\" \"pnpm --filter @t3ck/product-service dev\" \"pnpm --filter @t3ck/order-service dev\" \"pnpm --filter @t3ck/shipping-service dev\"",
    "dev:admin": "concurrently \"pnpm --filter @t3ck/admin-service dev\" \"pnpm --filter @t3ck/admin-dashboard dev\"",
    "dev:admin:unified": "concurrently \"pnpm --filter @t3ck/admin-service dev\" \"pnpm --filter @t3ck/tenant-service dev\" \"pnpm --filter @t3ck/api-gateway dev\" \"pnpm --filter @t3ck/admin-unified-dashboard dev\"",
    "dev:performance": "concurrently \"pnpm --filter @t3ck/media-service dev\" \"pnpm --filter @t3ck/edge-service dev\"",
    "dev:with-gateway": "concurrently \"pnpm dev:gateway\" \"pnpm dev:core\" \"pnpm dev:admin\" \"pnpm dev:performance\"",
    "setup": "bash scripts/setup.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "axios": "^1.13.5",
      "fast-xml-parser": "^5.3.6",
      "@humanwhocodes/config-array>minimatch": "3.1.3",
      "eslint-plugin-import>minimatch": "3.1.3",
      "@sentry/node>minimatch": "9.0.6",
      "glob@7.1.6>minimatch": "3.1.3",
      "glob@7.2.3>minimatch": "3.1.3",
      "glob@10.5.0>minimatch": "9.0.6"
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "dotenv": "^16.4.5",
    "bullmq": "^5.67.2",
    "express-rate-limit": "^8.2.1",
    "mysql2": "^3.16.2",
    "rate-limit-redis": "^4.3.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  }
}
