{
  "name": "@t3ck/admin-service",
  "version": "1.0.0",
  "description": "Administração central: dashboard, produtos, pedidos, clientes, analytics, settings, usuários e audit logs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "migrate:theme": "ts-node src/migrations/20260506000100-create-admin-unified-theme-firestore-schema.ts",
    "migrate:customers": "ts-node src/migrations/20260506000200-create-admin-unified-customer-crm-firestore-schema.ts",
    "migrate:audit": "ts-node src/migrations/20260506000300-create-admin-unified-audit-firestore-schema.ts",
    "migrate:products": "ts-node src/migrations/20260506000400-create-admin-unified-products-firestore-schema.ts",
    "migrate:orders": "ts-node src/migrations/20260506000500-create-admin-unified-orders-firestore-schema.ts",
    "migrate:migration": "ts-node src/migrations/20260511000100-create-admin-unified-migration-firestore-schema.ts",
    "migrate:migration:columns": "ts-node src/migrations/20260511000200-update-admin-unified-migration-column-mappings.ts",
    "migrate:migration:normalized-records": "ts-node src/migrations/20260511000300-complete-admin-unified-migration-normalized-records.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@t3ck/shared": "workspace:*",
    "express": "^4.18.2",
    "firebase-admin": "12.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  }
}
