rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Regras para uploads de imagens de produtos
    match /tenants/{tenantId}/products/{productId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        request.auth.token.tenant_id == tenantId &&
        request.auth.token.roles.hasAny(['admin', 'manager']) &&
        request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }
    
    // Regras para documentos
    match /tenants/{tenantId}/documents/{allPaths=**} {
      allow read: if request.auth != null && 
        request.auth.token.tenant_id == tenantId;
      allow write: if request.auth != null && 
        request.auth.token.tenant_id == tenantId &&
        request.auth.token.roles.hasAny(['admin', 'manager']);
    }
  }
}
